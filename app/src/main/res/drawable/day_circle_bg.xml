<?xml version="1.0" encoding="utf-8"?>
<!-- Circular day toggle: filled beige when selected, white outline otherwise. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="@color/day_selected" />
            <stroke android:width="2dp" android:color="@color/outline" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/day_unselected" />
            <stroke android:width="2dp" android:color="@color/outline" />
        </shape>
    </item>
</selector>
