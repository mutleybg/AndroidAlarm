<?xml version="1.0" encoding="utf-8"?>
<!--
  A single alarm filling the screen. Wrapped in a ScrollView so that on very
  small / low-resolution screens the content scrolls instead of clipping;
  fillViewport lets the panel centre itself vertically when there is spare room.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <com.example.androidalarm.AlarmPanelView
        android:id="@+id/alarmPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="0dp"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:padding="16dp" />

</ScrollView>
